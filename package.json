{
  "name": "mpcp-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "mpcp": "./dist/cli/index.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "mpcp": "node dist/cli/index.js",
    "demo:verify": "node scripts/demo-verify.mjs",
    "example:parking": "node examples/parking-session/generate.mjs",
    "example:guardrails": "node examples/parking-session/demo-guardrails.mjs"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
